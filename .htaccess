Options +FollowSymLinks -MultiViews
RewriteEngine On
RewriteBase /~uapv2500969/

# -----------------------------------
# PAGES D'AUTHENTIFICATION
# -----------------------------------
RewriteRule ^connexion/?$ Controller/controller_login.php [L,QSA]
RewriteRule ^inscription/?$ Controller/controller_register.php [L,QSA]

# -----------------------------------
# PAGES DU MENU UTILISATEUR
# -----------------------------------
RewriteRule ^paiement/?$ Controller/controller_menu.php?user_pageID=payment [L,QSA]
RewriteRule ^profile/?$ Controller/controller_menu.php?user_pageID=profile [L,QSA]
RewriteRule ^parametres/?$ Controller/controller_menu.php?user_pageID=parameter [L,QSA]
# Si tu as une page profil :
# RewriteRule ^profil/?$ Controller/controller_menu.php?user_pageID=profile [L,QSA]

# -----------------------------------
# PAGES LÉGALES & SUPPORT
# -----------------------------------
RewriteRule ^support/?$ Controller/controller_legal.php?legalID=support [L,QSA]
RewriteRule ^condition/?$ Controller/controller_legal.php?legalID=condition [L,QSA]
RewriteRule ^confidentialite/?$ Controller/controller_legal.php?legalID=confidentialite [L,QSA]
# Si tu as une page mentions légales :
# RewriteRule ^mentions-legales/?$ Controller/controller_legal.php?page=legal [L,QSA]

# -----------------------------------
# PAGES DES JEUX (Règle dynamique)
# -----------------------------------
# Cette règle capture n'importe quel mot après "game/" et le passe dans la variable ?game=
RewriteRule ^game/([a-zA-Z0-9_-]+)/?$ Controller/controller_game.php?game=$1 [L,QSA]

# Si tu as une page qui liste tous les jeux (l'accueil des jeux) :
# RewriteRule ^jeux/?$ Controller/controller_game.php [L,QSA]

# -----------------------------------
# PAGE D'ACCUEIL
# -----------------------------------
RewriteRule ^home/?$ index.php [L,QSA]

# Optionnel : Rediriger l'accès direct à index.php vers /home
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*index\.php\ HTTP/
RewriteRule ^(.*)index\.php$ home [R=301,L]

# -----------------------------------
# PAGES DU BACK-OFFICE (ADMIN)
# -----------------------------------
RewriteRule ^admin/?$ admin/admin.php [L,QSA]
RewriteRule ^admin/dashboard/?$ admin/admin.php [L,QSA]

# --- Gestion des Jeux ---
# URL type : /admin/jeux/delete_case/1/box_123
RewriteRule ^admin/jeux/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_admingames.php?action_game=$1&id=$2&case_id=$3 [L,QSA]
# URL type : /admin/jeux/proba/1
RewriteRule ^admin/jeux/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_admingames.php?action_game=$1&id=$2 [L,QSA]
# URL type : /admin/jeux/add_case
RewriteRule ^admin/jeux/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_admingames.php?action_game=$1 [L,QSA]
# URL type : /admin/jeux
RewriteRule ^admin/jeux/?$ admin/Controller/controller_admingames.php [L,QSA]

# --- Gestion Utilisateurs ---
RewriteRule ^admin/utilisateurs/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_adminusers.php?action_user=$1&id=$2 [L,QSA]
RewriteRule ^admin/utilisateurs/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_adminusers.php?action_user=$1 [L,QSA]
RewriteRule ^admin/utilisateurs/?$ admin/Controller/controller_adminusers.php [L,QSA]

# --- Gestion de la FAQ ---
RewriteRule ^admin/faq/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_adminfaq.php?action_faq=$1&id=$2 [L,QSA]
RewriteRule ^admin/faq/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_adminfaq.php?action_faq=$1 [L,QSA]
RewriteRule ^admin/faq/?$ admin/Controller/controller_adminfaq.php [L,QSA]

# --- Gestion des Mails ---
# URL type : /admin/mails/status/1/read
RewriteRule ^admin/mails/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_mail.php?action_mail=$1&id=$2&status=$3 [L,QSA]
RewriteRule ^admin/mails/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_mail.php?action_mail=$1&id=$2 [L,QSA]
RewriteRule ^admin/mails/([a-zA-Z0-9_-]+)/?$ admin/Controller/controller_mail.php?action_mail=$1 [L,QSA]
RewriteRule ^admin/mails/?$ admin/Controller/controller_mail.php [L,QSA]

RewriteRule ^plan-du-site/?$ Controller/controller_sitemap.php [L,QSA]

# Connexion Administrateur
RewriteRule ^admin/connexion/?$ admin/Controller/controller_login.php [L,QSA]